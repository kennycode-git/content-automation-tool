# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key — server-side only, never expose to frontend
SUPABASE_JWT_SECRET=your-jwt-secret   # from Supabase dashboard > Settings > API

# ── Unsplash ──────────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ── Pexels ────────────────────────────────────────────────────────────────────
PEXELS_ACCESS_KEY=your_pexels_access_key   # from pexels.com/api

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...   # or sk_test_... for development
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app   # used for CORS allow-origin
RAILWAY_PUBLIC_DOMAIN=your-backend.up.railway.app

# ── TikTok ────────────────────────────────────────────────────────────────────
# TIKTOK_CLIENT_KEY=your_client_key         # from TikTok developer portal
# TIKTOK_CLIENT_SECRET=your_client_secret   # from TikTok developer portal
# TIKTOK_REDIRECT_URI=https://<railway-domain>/api/tiktok/callback

# ── Development only ──────────────────────────────────────────────────────────
# ENABLE_DOCS=true   # enables /docs (Swagger UI) — never set in production
PYTHONUNBUFFERED=1
